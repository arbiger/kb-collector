# KB Collector Configuration

# Obsidian Vault Path
# Example: ~/Documents/Knowledge
VAULT_PATH=~/Documents/Knowledge

# Default Author for notes (Who is running the tool)
NOTE_AUTHOR=User

# AI Provider (openai, anthropic, gemini, or none)
# Set to 'none' if you want an AI agent to handle summarization via CLI
AI_PROVIDER=none

# --- OPTIONAL: Internal AI Keys ---
# Only needed if AI_PROVIDER is not 'none'
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# --- OPTIONAL: Extra Features ---
# Tavily API Key for Nightly Research
TAVILY_API_KEY=
# Email settings for reports
RECIPIENT_EMAIL=your-email@example.com
