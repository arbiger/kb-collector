# KB Collector Configuration

# Obsidian Vault Path
# Example: /Users/yourname/Documents/Knowledge
VAULT_PATH=~/Documents/Knowledge

# Default Author for notes
NOTE_AUTHOR=User

# AI Provider (openai, anthropic, gemini)
AI_PROVIDER=openai

# API Keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Tavily API Key for Nightly Research
TAVILY_API_KEY=

# Email settings for reports
RECIPIENT_EMAIL=your-email@example.com
